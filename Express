<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Express Aluguel de Tambores para Entulho - Ribeirão Preto</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        /* --- ESTILOS GERAIS E CORES --- */
        :root {
            --primary-blue: #1E6FA8;
            --accent-orange: #F97316;
            --dark-bg: #111111;
            --card-bg: #1A1A1A;
            --text-white: #FFFFFF;
            --text-gray: #CCCCCC;
            --price-yellow: #FFD700;
            --whatsapp-green: #25D366;
            --font-main: 'Outfit', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-main);
            background-color: var(--dark-bg);
            color: var(--text-white);
            line-height: 1.6;
        }

        h1, h2, h3 {
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        /* --- UTILITÁRIOS --- */
        .container {
            width: 100%;
            padding-right: 20px;
            padding-left: 20px;
            margin-right: auto;
            margin-left: auto;
        }

        @media (min-width: 576px) { .container { max-width: 540px; } }
        @media (min-width: 768px) { .container { max-width: 720px; } }
        @media (min-width: 992px) { .container { max-width: 960px; } }
        @media (min-width: 1200px) { .container { max-width: 1140px; } }

        .btn-whatsapp {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background-color: var(--whatsapp-green);
            color: white;
            font-weight: 800;
            text-transform: uppercase;
            padding: 15px 30px;
            border-radius: 50px;
            font-size: 1.1rem;
            width: 100%;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
        }

        .btn-whatsapp:hover {
            transform: scale(1.03);
            box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
        }

        .section-title {
            font-size: 2rem;
            color: var(--primary-blue);
            text-align: center;
            margin-bottom: 40px;
        }

        .highlight-yellow {
            color: var(--price-yellow);
        }

        /* --- BARRA DE ALERTA --- */
        .alert-bar {
            background-color: var(--accent-orange);
            color: white;
            text-align: center;
            padding: 10px 0;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.9rem;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* --- HERO SECTION --- */
        .hero {
            padding: 60px 0;
            background: radial-gradient(circle at center, #222 0%, #111 100%);
            text-align: center;
        }

        .logo-placeholder {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-orange));
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
            font-weight: 900;
            border: 4px solid #fff;
        }

        .hero-headline {
            font-size: 2.5rem;
            line-height: 1.1;
            margin-bottom: 20px;
        }

        .hero-price {
            font-size: 3.5rem;
            color: var(--price-yellow);
            font-weight: 900;
            margin-bottom: 20px;
            display: block;
        }

        .tambores-img-placeholder {
            width: 100%;
            max-width: 300px;
            height: 250px;
            background-color: var(--primary-blue);
            border-radius: 15px;
            margin: 30px auto;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            border: 5px solid #333;
            position: relative;
            box-shadow: 0 0 30px rgba(30, 111, 168, 0.4);
        }

        /* --- SEÇÃO PROBLEMAS --- */
        .problemas {
            padding: 60px 0;
            background-color: #151515;
        }

        .problemas-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .problema-card {
            background-color: var(--card-bg);
            padding: 30px;
            border-radius: 10px;
            border-left: 4px solid #444;
            transition: border-color 0.3s;
        }

        .problema-card:hover {
            border-left-color: var(--accent-orange);
        }

        .problema-icon {
            font-size: 2rem;
            color: var(--accent-orange);
            margin-bottom: 15px;
        }

        .problema-card h3 {
            font-size: 1.3rem;
            margin-bottom: 10px;
            color: white;
        }

        .problema-card p {
            color: var(--text-gray);
            font-size: 1rem;
        }

        /* --- SEÇÃO COMO FUNCIONA --- */
        .como-funciona {
            padding: 60px 0;
        }

        .passos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            text-align: center;
        }

        .passo-card {
            position: relative;
            padding: 20px;
        }

        .passo-numero {
            font-size: 4rem;
            font-weight: 900;
            color: rgba(30, 111, 168, 0.2);
            position: absolute;
            top: -20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1;
        }

        .passo-icon {
            font-size: 3rem;
            color: var(--primary-blue);
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }

        .passo-card h3 {
            font-size: 1.4rem;
            margin-bottom: 10px;
        }

        /* --- SEÇÃO PREÇOS --- */
        .precos {
            padding: 60px 0;
            background-color: #151515;
        }

        .precos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            align-items: start;
        }

        .preco-card {
            background-color: var(--card-bg);
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            border: 2px solid #333;
            transition: transform 0.3s, border-color 0.3s;
        }

        .preco-card.destaque {
            border-color: var(--primary-blue);
            background-color: #1a2530;
            transform: scale(1.05);
            position: relative;
        }

        .oferta-badge {
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            background-color: var(--accent-orange);
            color: white;
            padding: 5px 15px;
            border-radius: 50px;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.8rem;
        }

        .preco-card h3 {
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        .preco-valor {
            font-size: 3rem;
            font-weight: 900;
            color: var(--price-yellow);
            margin-bottom: 5px;
        }

        .preco-sub {
            font-size: 1rem;
            color: var(--text-gray);
            margin-bottom: 25px;
            display: block;
        }

        .preco-lista {
            text-align: left;
            margin-bottom: 30px;
            color: var(--text-gray);
        }

        .preco-lista li {
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .preco-lista i {
            color: var(--primary-blue);
        }

        /* --- SEÇÃO DIFERENCIAIS --- */
        .diferenciais {
            padding: 60px 0;
        }

        .dif-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        @media (min-width: 768px) {
            .dif-grid { grid-template-columns: repeat(3, 1fr); }
        }

        .dif-card {
            background-color: var(--card-bg);
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }

        .dif-icon {
            font-size: 2rem;
            color: var(--primary-blue);
            margin-bottom: 10px;
        }

        .dif-card h4 {
            font-size: 1rem;
            font-weight: 800;
        }

        /* --- SEÇÃO DEPOIMENTOS --- */
        .depoimentos {
            padding: 60px 0;
            background-color: #151515;
        }

        .depo-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .depo-card {
            background-color: var(--card-bg);
            padding: 25px;
            border-radius: 10px;
            position: relative;
        }

        .depo-aspas {
            font-size: 3rem;
            color: #333;
            position: absolute;
            top: 10px;
            right: 20px;
        }

        .depo-stars {
            color: var(--price-yellow);
            margin-bottom: 15px;
        }

        .depo-text {
            color: var(--text-gray);
            font-style: italic;
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }

        .depo-autor {
            font-weight: 700;
            color: white;
        }

        .depo-cidade {
            font-size: 0.9rem;
            color: var(--primary-blue);
        }

        /* --- CTA FINAL --- */
        .cta-final {
            padding: 80px 0;
            background: linear-gradient(180deg, #111 0%, #1a2530 100%);
            text-align: center;
        }

        .cta-final h2 {
            font-size: 2.5rem;
            line-height: 1.1;
            margin-bottom: 15px;
        }

        .cta-final .urgencia {
            color: var(--accent-orange);
            font-weight: 800;
            display: block;
            margin-bottom: 20px;
        }

        .cta-final p {
            font-size: 1.2rem;
            color: var(--text-gray);
            margin-bottom: 40px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        /* --- RODAPÉ --- */
        footer {
            padding: 30px 0;
            text-align: center;
            border-top: 1px solid #333;
            font-size: 0.9rem;
            color: var(--text-gray);
        }
    </style>
</head>
